{
  "name": "typenstein3d",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "start": "python -m http.server 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:view": "open ./coverage/index.html",
    "ts:format:check": "prettier . --check",
    "ts:format:write": "prettier . --write",
    "ts:compile": "tsc",
    "ts:watch": "tsc -watch",
    "ts:lint": "eslint src tests",
    "build:docs": "typedoc --entryPointStrategy Expand src"
  },
  "keywords": [],
  "author": "Justin Horner",
  "description": "A browser-based typing game inspired by Wolfenstein 3D",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/p5": "^1.7.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
